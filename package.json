{
  "name": "worclaude",
  "version": "1.6.0",
  "description": "CLI tool that scaffolds a comprehensive Claude Code workflow into any project",
  "type": "module",
  "bin": {
    "worclaude": "./src/index.js"
  },
  "main": "src/index.js",
  "files": [
    "src/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sefaertunc/Worclaude.git"
  },
  "homepage": "https://github.com/sefaertunc/Worclaude#readme",
  "bugs": {
    "url": "https://github.com/sefaertunc/Worclaude/issues"
  },
  "author": "Sefa Ertunç",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "format": "prettier --write .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "npm test && npm run lint"
  },
  "keywords": [
    "claude",
    "claude-code",
    "workflow",
    "scaffolding",
    "cli",
    "developer-tools",
    "productivity",
    "ai",
    "anthropic",
    "agents",
    "automation"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "inquirer": "^12.5.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "vitepress": "^1.6.4",
    "vitest": "^3.0.9"
  }
}
