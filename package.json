{
  "name": "worclaude",
  "version": "2.9.3",
  "description": "The Workflow Layer for Claude Code — scaffold agents, commands, skills, hooks, and memory into any project",
  "type": "module",
  "bin": {
    "worclaude": "src/index.js"
  },
  "main": "src/index.js",
  "files": [
    "src/",
    "templates/",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sefaertunc/Worclaude.git"
  },
  "homepage": "https://github.com/sefaertunc/Worclaude#readme",
  "bugs": {
    "url": "https://github.com/sefaertunc/Worclaude/issues"
  },
  "funding": "https://github.com/sponsors/sefaertunc",
  "author": "Sefa Ertunç",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "format": "prettier --write .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "npm test && npm run lint"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "claude",
    "claude-code",
    "claude-code-workflow",
    "claude-code-scaffolding",
    "workflow",
    "scaffolding",
    "hooks",
    "memory",
    "cli",
    "developer-tools",
    "productivity",
    "ai",
    "anthropic",
    "agents",
    "automation"
  ],
  "license": "MIT",
  "dependencies": {
    "@sefaertunc/anthropic-watch-client": "^1.0.2",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "inquirer": "^12.5.0",
    "ora": "^9.4.0",
    "smol-toml": "^1.6.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "eslint": "^10.2.1",
    "prettier": "^3.5.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "brace-expansion": "^1.1.13",
    "esbuild": "^0.25.0",
    "vite": "^6.4.2",
    "postcss": "^8.5.10"
  }
}
