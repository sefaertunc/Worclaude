# Snyk (https://snyk.io) policy file
# Excludes scanner test fixtures from Snyk Open Source scans.
# These are static manifests used by src/core/project-scanner/ detectors —
# never installed, not shipped to npm, not executed. See SECURITY.md.
version: v1.25.0
exclude:
  global:
    - tests/fixtures/**
ignore: {}
patch: {}
